@inject NavigationManager Nav

<nav class="d-flex flex-column bg-dark text-white" style="width:220px;min-height:100vh">
    <div class="p-3 border-bottom border-secondary">
        <i class="bi bi-hexagon-fill text-primary me-2"></i>
        <strong>DataBridge</strong>
    </div>

    <ul class="nav flex-column mt-2 px-2">
        <NavItem Href="/" Icon="house" Label="Home" />
        <NavItem Href="/products"  Icon="basket2-fill"     Label="Products"  />
