@inherits LayoutComponentBase

<div class="d-flex" style="min-height:100vh">
    <NavMenu />

    <main class="flex-grow-1 d-flex flex-column">
        <nav class="navbar navbar-dark bg-primary px-3 shadow-sm" style="min-height:56px">
            <span class="navbar-brand mb-0">
                <i class="bi bi-database-fill-gear me-2"></i>DataBridge
            </span>
            <div class="ms-auto d-flex gap-2 align-items-center">
                <a href="http://localhost:5000/swagger" target="_blank"
                   class="btn btn-sm btn-outline-light">
                    <i class="bi bi-braces-asterisk me-1"></i>Swagger API
                </a>
            </div>
        </nav>

        <div class="p-4 flex-grow-1 bg-light">
            @Body
        </div>

        <footer class="text-center text-muted small py-2 bg-white border-top">
            DataBridge &mdash; Multi-source Unit of Work &mdash; .NET 8 / Blazor Server
        </footer>
    </main>
</div>
