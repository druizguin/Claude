@inject DataBridgeApiClient Api

<div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.5)">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-cart-plus me-2"></i>New Purchase</h5>
                <button class="btn-close" @onclick="OnCancel"></button>
            </div>
            <div class="modal-body">
                @if (_loadingData)
                {
                    <div class="text-center py-3">
                        <div class="spinner-border text-primary"></div>
                    </div>
                }
                else
                {
                    <div class="mb-3">
                        <label class="form-label">User <span class="text-danger">*</span></label>
                        <select class="form-select @(UserErr?"is-invalid":"")" @bind="_userId">
                            <option value="">— Select user —</option>
                            @foreach (var u in _users)
                            {
                                <option value="@u.Id">@u.Name (@u.Email)</option>
                            }
                        </select>
                        @if (UserErr) { <div class="invalid-feedback">Required.</div> }
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Product <span class="text-danger">*</span></label>
                        <select class="form-select @(ProdErr?"is-invalid":"")"
                                value="@_productId"
                                @onchange="OnProductChanged">
                            <option value="">— Select product —</option>
                            @foreach (var p in _products)
                            {
                                <option value="@p.Id">@p.Name — @p.Price.ToString("C2")</option>
                            }
                        </select>
                        @if (ProdErr) { <div class="invalid-feedback">Required.</div> }
                    </div>
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="form-label">Quantity</label>
                            <input class="form-control" type="number" min="1"
                                   @bind="_qty" @bind:after="CalcTotal" />
                        </div>
                        <div class="col-6">
                            <label class="form-label">Total Price</label>
                            <div class="input-group">
                                <span class="input-group-text">€</span>
                                <input class="form-control" type="number" step="0.01"
                                       @bind="_total" readonly />
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="OnCancel" disabled="@_saving">Cancel</button>
                <button class="btn btn-primary" @onclick="Save" disabled="@(_saving || _loadingData)">
                    @if (_saving) { <span class="spinner-border spinner-border-sm me-2"></span> }
                    Save
                </button>
            </div>
            @if (_error != null) { <div class="alert alert-danger m-3 mb-0 p-2 small">@_error</div> }
        </div>
    </div>
</div>

@code {
    [Parameter] public EventCallback OnSave   { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private List<UserDto>    _users    = new();
    private List<ProductDto> _products = new();
    private string  _userId = "", _productId = "";
    private int     _qty    = 1;
    private decimal _total;
    private bool    _saving, _loadingData = true, _submitted;
    private string? _error;

    private bool UserErr => _submitted && string.IsNullOrEmpty(_userId);
    private bool ProdErr => _submitted && string.IsNullOrEmpty(_productId);

    protected override async Task OnInitializedAsync()
    {
        var specUsers    = new QuerySpec { Page = new PageSpec { Offset = 100 } };
        var specProducts = new QuerySpec { Page = new PageSpec { Offset = 100 } };
        var (users, _)    = await Api.QueryAsync<UserDto>("users", specUsers);
        var (products, _) = await Api.QueryAsync<ProductDto>("products", specProducts);
        _users    = users;
        _products = products;
        _loadingData = false;
    }

    private void OnProductChanged(ChangeEventArgs e)
    {
        _productId = e.Value?.ToString() ?? "";
        CalcTotal();
    }

    private void CalcTotal()
    {
        var prod = _products.FirstOrDefault(p => p.Id == _productId);
        _total   = prod != null ? prod.Price * _qty : 0;
    }

    private async Task Save()
    {
        _submitted = true;
        if (UserErr || ProdErr) return;
        _saving = true; _error = null;
        try
        {
            var attrs = new
            {
                UserId       = _userId,
                ProductId    = _productId,
                Quantity     = _qty,
                TotalPrice   = _total,
                Status       = "completed"
            };
            await Api.CreateAsync<PurchaseDto>("purchases", attrs);
            await OnSave.InvokeAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _saving = false; }
    }
}
